{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-blazor-app",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/AbeGamingBlazorApp/AbeGamingBlazorApp.csproj"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "watch-blazor-app",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "watch",
        "run",
        "--project",
        "${workspaceFolder}/AbeGamingBlazorApp/AbeGamingBlazorApp.csproj"
      ],
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "csharp",
          "fileLocation": "absolute",
          "pattern": {
            "regexp": "^(.*)$",
            "message": 1
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^.*dotnet watch.*$",
            "endsPattern": "^.*Now listening on:\\s+https?://.*$"
          }
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      }
    }
  ]
}
